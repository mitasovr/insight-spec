apiVersion: v1
kind: Secret
metadata:
  name: insight-youtrack-main
  namespace: data
  labels:
    app.kubernetes.io/part-of: insight
  annotations:
    insight.cyberfabric.com/connector: youtrack
    insight.cyberfabric.com/source-id: youtrack-main
type: Opaque
stringData:
  # Required — YouTrack base URL (no trailing slash).
  # Cloud example:       https://myorg.youtrack.cloud
  # Self-hosted example: https://youtrack.myorg.local
  youtrack_base_url: "https://myorg.youtrack.cloud"

  # Required — YouTrack permanent token (Profile → Account Security → Tokens).
  # Must have read access to all projects the service account can see plus
  # /api/admin/projects/{id}/customFields for project-level lookups.
  # The connector syncs EVERYTHING the token can reach — no project whitelist.
  youtrack_token: "CHANGE_ME"

  # Optional — earliest issue updated timestamp to sync from (YYYY-MM-DD).
  # Default: 2020-01-01.
  # youtrack_start_date: "2024-01-01"

  # Optional — page size for issue search ($top). 1..500. Default: 100.
  # youtrack_page_size: "100"

  # Optional — page size for activitiesPage cursor ($top). 1..500. Default: 200.
  # youtrack_activities_page_size: "200"
