apiVersion: v1
kind: Secret
metadata:
  name: insight-hubspot-main
  namespace: data
  labels:
    app.kubernetes.io/part-of: insight
  annotations:
    insight.cyberfabric.com/connector: hubspot
    insight.cyberfabric.com/source-id: hubspot-main
type: Opaque
stringData:
  # Required — HubSpot Private App access token (begins with "pat-...").
  # Settings → Integrations → Private Apps → Create private app.
  hubspot_access_token: "CHANGE_ME"

  # Optional — earliest date to sync (YYYY-MM-DD). Default: two years before now.
  # hubspot_start_date: "2024-01-01"

  # Optional — JSON array of stream names to override the curated default.
  # hubspot_streams: '["contacts", "companies", "deals"]'

  # Optional — concurrent cursor window. Default: P30D. Shrink to PT1H on busy
  # portals to stay under the 10k search-result cap per slice.
  # hubspot_stream_slice_step: "P30D"

  # Optional — re-read window for hs_lastmodifieddate eventual consistency. Default: PT10M.
  # hubspot_lookback_window: "PT10M"

  # Optional — max concurrent slice fetches (1–50). Default: 4.
  # hubspot_num_workers: "4"

  # Optional — fetch archived/soft-deleted records alongside active. Default: true.
  # hubspot_include_archived: "true"
