apiVersion: v1
kind: Secret
metadata:
  name: insight-claude-admin-main
  namespace: data
  labels:
    app.kubernetes.io/part-of: insight
  annotations:
    insight.cyberfabric.com/connector: claude-admin
    insight.cyberfabric.com/source-id: claude-admin-main
type: Opaque
stringData:
  # Required — Anthropic Admin API key with organization-level read scope.
  # Created at console.anthropic.com by an organization admin.
  admin_api_key: "CHANGE_ME"

  # Optional — earliest date to collect usage / cost / code-usage data from.
  # Must be full ISO 8601 with time component (e.g. 2026-01-01T00:00:00Z) —
  # the messages_usage and cost_report streams use strict datetime parsing and
  # reject bare YYYY-MM-DD. Defaults to 90 days ago.
  # start_date: "2026-01-01T00:00:00Z"

  # NOTE: insight_source_id is NOT a stringData field. It is injected from the
  # insight.cyberfabric.com/source-id annotation on this Secret (see metadata
  # above). Setting it here has no effect.
