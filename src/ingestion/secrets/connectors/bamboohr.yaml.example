apiVersion: v1
kind: Secret
metadata:
  name: insight-bamboohr-main
  labels:
    app.kubernetes.io/part-of: insight
  annotations:
    insight.cyberfabric.com/connector: bamboohr
    insight.cyberfabric.com/source-id: bamboohr-main
    # Optional fields may be omitted from the live Secret without triggering
    # a validate.sh ERROR (the connector falls back to its defaults).
    insight.cyberfabric.com/optional-fields: "bamboohr_employees_custom_fields,bamboohr_start_date"
type: Opaque
stringData:
  bamboohr_api_key: "CHANGE_ME"
  bamboohr_domain: "CHANGE_ME"
  bamboohr_employees_custom_fields: "[]"       # Optional: extra employee custom fields
  bamboohr_start_date: "2020-01-01"            # Optional: leave-requests history start date
