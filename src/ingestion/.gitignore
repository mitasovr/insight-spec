# Secrets — never commit credentials
.env.local
*.env.local

# Tenant configs with real credentials (only .yaml.example is tracked)
connections/*.yaml
!connections/*.yaml.example

# Connection state (generated by apply-connections.sh)
connections/.state/

# Connector discovery output
catalog.json

# Generated CronWorkflows (created by sync-flows.sh from .tpl templates)
# Templates are tracked; tenant dirs are generated at deploy time
workflows/*/
!workflows/templates/
!workflows/schedules/
