# Required credentials for Zoom connector
# Create a Server-to-Server OAuth app at https://marketplace.zoom.us/
# Grant scopes: user:read:admin, dashboard_meetings:read:admin
#
insight_source_id: ""         # Instance ID (e.g. "zoom-main")
zoom_account_id: ""           # Zoom account ID
zoom_client_id: ""            # OAuth app client ID
zoom_client_secret: ""        # OAuth app client secret
start_date: ""                # Earliest date for incremental sync (YYYY-MM-DD)
