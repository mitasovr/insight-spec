# Required credentials for M365 connector
# Copy these fields to connections/{tenant}.yaml under connectors.m365
#
# To obtain these values:
#   1. Create an App Registration in Azure AD
#   2. Grant application permissions: Reports.Read.All, User.Read.All
#   3. Create a client secret
#
insight_source_id: ""     # Instance ID (e.g. "m365-main")
azure_tenant_id: ""       # Azure AD tenant ID
azure_client_id: ""       # App registration client ID
azure_client_secret: ""   # App registration client secret
